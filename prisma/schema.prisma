generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


//_____________________________________ Inicio BetterAuth, no tocar
  model User {
    id            String    @id
    name          String
    email         String
    emailVerified Boolean   @default(false)
    image         String?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt
    sessions      Session[]
    accounts      Account[]

    role       String?
    banned     Boolean?  @default(false)
    banReason  String?
    banExpires DateTime?

    lastName   String

    pays        Pay[]
    reservations Reservation[]
    stays        Stay[]

    @@unique([email])
    @@map("user")
  }

  model Session {
    id        String   @id
    expiresAt DateTime
    token     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    impersonatedBy String?

    @@unique([token])
    @@index([userId])
    @@map("session")
  }

  model Account {
    id                    String    @id
    accountId             String
    providerId            String
    userId                String
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    @@index([userId])
    @@map("account")
  }

  model Verification {
    id         String   @id
    identifier String
    value      String
    expiresAt  DateTime
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([identifier])
    @@map("verification")
  }
//_____________________________________ Final BetterAuth


enum TypeRoom {
  Simple
  Matrimonial
  Doble
  Doble_Familiar
  Cuadruple
  Triple
  Triple_Familiar
}

enum TypeStatus {
  free
  busy
  reserved
  disabled
}

model Room {
  number   Int @id
  type     TypeRoom
  active   Boolean
  status   TypeStatus @default(free)
  floor    Int
  
  price    Float?
  posW     Float?
  posH     Float?

  stays      Stay[]
  roomActive RoomActive[]

  roomInReservation RoomInReservation[]

  
  @@map("room")
}


model RoomActive {
  id            Int @id @default(autoincrement())
  description   String
  dateCreated   DateTime
  active        Boolean
  
  dateMoved     DateTime?
  room          Int?

  roomRelation  Room? @relation(fields: [room], references: [number])

  @@map("roomActive")
}


model Country{
  id        String @id
  name      String
  flag      String

  clients   Client[]

  @@map("country")
}

enum TypeDocuments {
  DNI
  CI_Brazil
  DNI_Argentina
  Pasaporte
  Carnet_Extranjeria
  Otros
}


model Client{
  id              String @id @default(uuid())
  typeDocument    TypeDocuments
  numberDocument  String
  firstName       String
  lastName        String
  countryId       String
  stars           Float @default(0)
  totalStays      Int @default(0)
  lastStay        DateTime?
  address         String?
  phone           String?
  comments        String?
  born            DateTime
  createdAt       DateTime @default(now())


  banned          Boolean @default(false)
  banReason       String?

  country         Country @relation(fields: [countryId], references: [id])
  clientInStay    ClientInStay[] //! CAMBIAR AL IMPLEMENTAR EESTADIAS

  @@unique([typeDocument,numberDocument])

  @@index([countryId])
  @@index([firstName])
  @@index([lastName])

  @@map("client")
}


model ClientInStay{
  id        Int @id @default(autoincrement())
  clientId  String
  stayId    Int
  chassis   String?

  client  Client @relation( fields: [clientId], references: [id] )
  stay    Stay   @relation( fields: [stayId],   references: [id], onDelete: Cascade )

  @@unique([clientId,stayId])
  @@map("client-stay")
}


enum Reason {
  Vacaciones
  Visita
  Educacion
  Salud
  Religion
  Compras
  Negocios
  Otros
}

model Stay{
  id          Int @id @default(autoincrement())
  dateStart   DateTime
  paidUntil   DateTime
  dateEnd     DateTime? // si la fecha de salida es null, se asume que la estadia esta activa
  userId      String
  roomId      Int
  totalCost   Float?
  stars       Int? @default(0)
  reason      Reason?
  origin      String
  carPlate    String?
  comments    String?
  images      String?
  companyId   Int?

  room        Room @relation(fields: [roomId],references: [number])
  user        User @relation(fields: [userId],references: [id])

  pays          Pay[]
  clientInStay  ClientInStay[]
  clientCompany ClientCompany? @relation(fields: [companyId], references: [id])

  @@map("stay")
}

enum PayType {
  efectivo
  electronico
}

model Pay {
  id                Int @id @default(autoincrement())
  date              DateTime
  description       String
  userId            String
  payType           PayType @default(efectivo)
  mount             Float

  operationNumber   String?
  stayId            Int?
  startDayDate      DateTime?
  endDayDate        DateTime?
  
  stay              Stay? @relation(fields: [stayId], references: [id], onDelete: Cascade)
  user              User @relation(fields: [userId], references: [id])

  @@map("pay")
}

model DayComment {
  id      Int @id @default(autoincrement())
  date    DateTime
  comment String
  
  @@map("report-comments")
}


model RoomInReservation{
  id            Int @id @default(autoincrement())
  roomId        Int @unique
  reservationId Int

  room          Room @relation(fields: [roomId], references: [number])
  reservation   Reservation @relation(fields: [reservationId],references: [id],onDelete: Cascade)

  @@map("room-reservation")
}


model Reservation {
  id          Int @id @default(autoincrement())
  name        String
  persons     Int
  date        DateTime
  amount      Float
  phone       String?

  userId      String
  user        User @relation(fields: [userId],references: [id])

  roomInReservation RoomInReservation[]

  @@map("reservation")
}


model ClientCompany {
  id            Int @id @default(autoincrement())
  name          String @unique
  dayPrice      Float
  chassisList   String[]
  fileUrl       String?

  stays         Stay[]

  @@map("client-companies")
  @@index([name])
}

